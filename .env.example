# Copy to .env.local and fill in. .env.local is gitignored.

# --- Scraping (required for the automation) ---
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Legal Notices fast-follow only (LLM prose extraction) ---
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Frontend (Vite) ---
# Convex deployment URL, from `npx convex dev`
VITE_CONVEX_URL=https://your-deployment.convex.cloud
# Clerk publishable key, from the Clerk dashboard
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- Convex environment variables (set via `npx convex env set` or the dashboard) ---
# FIRECRAWL_API_KEY   (same key as above; Convex actions read it at runtime)
# CLERK_JWT_ISSUER_DOMAIN   (e.g. https://your-app.clerk.accounts.dev)
